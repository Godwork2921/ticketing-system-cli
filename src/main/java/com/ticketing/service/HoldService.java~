package com.ticketing.service;

import com.ticketing.concurrency.EventLockManager;
import com.ticketing.dao.ReservationDAO;
import com.ticketing.dao.SeatDAO;
import com.ticketing.database.DBConnection;
import com.ticketing.enums.ReservationStatus;
import com.ticketing.enums.SeatStatus;
import com.ticketing.model.Reservation;
import com.ticketing.model.Seat;

import java.sql.Connection;
import java.time.Clock;
import java.time.LocalDateTime;
import java.util.concurrent.locks.ReentrantLock;

public class HoldService {

    private final ReservationDAO reservationDAO = new ReservationDAO();
    private final SeatDAO seatDAO = new SeatDAO();

    // IMPORTANT: inject clock for testability
    private final Clock clock = Clock.systemDefaultZone();

    public void holdSeat(
            String email,
            Long eventId,
            Long seatId,
            long ttlSeconds
    ) {

        ReentrantLock lock = EventLockManager.getLock(eventId);
        lock.lock();

        try (Connection conn = DBConnection.getConnection()) {

            conn.setAutoCommit(false);

            // =====================================================
            // IDEMPOTENCY CHECK
            // =====================================================
            if (reservationDAO.exists(conn, email, eventId, seatId)) {
                conn.rollback();
                throw new RuntimeException("Hold already exists");
            }

            // =====================================================
            // LOCK SEAT (DB PESSIMISTIC LOCK)
            // =====================================================
            Seat seat = seatDAO.findByIdForUpdate(conn, seatId);

            if (seat == null) {
                conn.rollback();
                throw new RuntimeException("Seat not found");
            }

            if (!seat.isAvailable()) {
                conn.rollback();
                throw new RuntimeException("Seat not available");
            }

            // =====================================================
            // DOMAIN ACTION (NOT RAW STATUS CHECKS)
            // =====================================================
            seat.reserve();

            // =====================================================
            // RESERVATION CREATION (CLEAN)
            // =====================================================
            LocalDateTime now = LocalDateTime.now(clock);
            LocalDateTime expiresAt = now.plusSeconds(ttlSeconds);

            Reservation hold = new Reservation(
                    email,
                    eventId,
                    seatId,
                    ReservationStatus.HOLDING,
                    now
            );



            // NOTE: ideally expiration should be set via domain method,
            // but your current model still allows setter (acceptable transitional stage)

            hold.setExpiration(clock, ttlSeconds);            // =====================================================
            // PERSIST
            // =====================================================
            reservationDAO.save(conn, hold);

            seatDAO.updateStatus(
                    conn,
                    seatId,
                    SeatStatus.RESERVED // IMPORTANT FIX (NOT HELD)
            );

            conn.commit();

        } catch (Exception e) {
            throw new RuntimeException("Failed to hold seat", e);

        } finally {
            lock.unlock();
        }
    }
}